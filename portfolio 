    <!-- Interactive Logic Node -->
    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');

        let score = 0;
        let paddleWidth = 75;
        let paddleHeight = 8;
        let paddleX = (canvas.width - paddleWidth) / 2;

        let blockX = Math.random() * (canvas.width - 15);
        let blockY = 0;
        let blockSpeed = 2.5;
        let blockSize = 14;

        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            const rootX = e.clientX - rect.left;
            paddleX = rootX - paddleWidth / 2;
            if(paddleX < 0) paddleX = 0;
            if(paddleX + paddleWidth > canvas.width) paddleX = canvas.width - paddleWidth;
        });

        function drawGame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Item Node (Updated to Neon Pink)
            ctx.fillStyle = '#ff007f';
            ctx.shadowBlur = 10;
            ctx.shadowColor = '#ff007f';
            ctx.fillRect(blockX, blockY, blockSize, blockSize);

            // Paddle Node (Updated to Neon Purple)
            ctx.fillStyle = '#bd00ff';
            ctx.shadowBlur = 10;
            ctx.shadowColor = '#bd00ff';
            ctx.fillRect(paddleX, canvas.height - paddleHeight - 12, paddleWidth, paddleHeight);

            // Reset shadows for fonts
            ctx.shadowBlur = 0;

            // Metrics Matrix Terminal Display (Updated style)
            ctx.fillStyle = '#a29bb8';
            ctx.font = '11px Courier New';
            ctx.fillText(' CAPTURED_NODES: ' + score, 15, 25);

            blockY += blockSpeed;

            if (blockY + blockSize >= canvas.height - paddleHeight - 12) {
                if (blockX + blockSize >= paddleX && blockX <= paddleX + paddleWidth) {
                    score++;
                    blockY = 0;
                    blockX = Math.random() * (canvas.width - blockSize);
                    blockSpeed += 0.25; 
                }
            }

            if (blockY > canvas.height) {
                score = 0;
                blockSpeed = 2.5;
                blockY = 0;
                blockX = Math.random() * (canvas.width - blockSize);
            }

            requestAnimationFrame(drawGame);
        }
        drawGame();
    </script>
